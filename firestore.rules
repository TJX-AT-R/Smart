
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SMART PASS - ABSOLUTE ADMIN SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Robust admin check.
     * Prioritizes the specific super-admin email for absolute access.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ncubethubelihle483@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isDataConsistent(userId) {
      return request.resource.data.userId == userId;
    }

    // --- COLLECTION RULES ---

    match /questions/{questionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();

      match /lessonProgress/{lessonProgressId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isDataConsistent(userId);
        allow update: if (isExistingOwner(userId) && isDataConsistent(userId)) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /testAttempts/{testAttemptId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isDataConsistent(userId);
        allow update: if (isExistingOwner(userId) && isDataConsistent(userId)) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();

        match /userAnswers/{userAnswerId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId) || isAdmin();
          allow delete: if isExistingOwner(userId) || isAdmin();
        }
      }

      match /purchases/{purchaseId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isDataConsistent(userId);
        allow update: if (isExistingOwner(userId) && isDataConsistent(userId)) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    // --- COLLECTION GROUP RULES ---
    // Critical for Admin Dashboard to function across all users.

    match /{path=**}/purchases/{purchaseId} {
      allow list, get: if isAdmin();
    }

    match /{path=**}/testAttempts/{testAttemptId} {
      allow list, get: if isAdmin();
    }

    match /{path=**}/lessonProgress/{progressId} {
      allow list, get: if isAdmin();
    }

    match /topics/{topicId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /lessons/{lessonId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }

      match /questions/{questionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();

        match /options/{optionId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isAdmin();
        }
      }
    }

    match /mockTests/{mockTestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studyResources/{studyResourceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
