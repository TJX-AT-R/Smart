
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a learner account in SmartPass.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "lastLoginDate": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "isPremium": { "type": "boolean", "description": "Whether the user has global access to all premium content." },
        "createdAt": { "type": "object", "description": "Firestore ServerTimestamp" }
      },
      "required": ["id", "email", "firstName", "lastName", "registrationDate"]
    },
    "Question": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Question",
      "type": "object",
      "description": "A theory test scenario.",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "category": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "explanation": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "text", "category", "options", "correctAnswer"]
    },
    "StudyResource": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyResource",
      "type": "object",
      "description": "A premium study booklet available for purchase.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priceDollars": { "type": "number" },
        "downloadUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "title", "priceDollars", "downloadUrl"]
    },
    "Purchase": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Purchase",
      "type": "object",
      "description": "An EcoCash transaction record requiring admin verification.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "studyResourceId": { "type": "string" },
        "resourceTitle": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "amountPaidDollars": { "type": "number" },
        "transactionId": { "type": "string", "description": "The reference code pasted by the user." },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "paymentMethod": { "type": "string" },
        "ecoCashNumber": { "type": "string" },
        "recipientNumber": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "userId", "transactionId", "status"]
    },
    "TestAttempt": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TestAttempt",
      "type": "object",
      "description": "A mock test or practice result.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "scorePercentage": { "type": "number" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "userId", "scorePercentage"]
    },
    "LessonProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LessonProgress",
      "type": "object",
      "description": "Tracking completion of specific theory modules.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "lessonId": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "completionDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "userId", "lessonId", "isCompleted"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Root learner profiles."
        }
      },
      {
        "path": "/questions/{questionId}",
        "definition": {
          "entityName": "Question",
          "schema": { "$ref": "#/backend/entities/Question" },
          "description": "Global theory repository."
        }
      },
      {
        "path": "/studyResources/{resourceId}",
        "definition": {
          "entityName": "StudyResource",
          "schema": { "$ref": "#/backend/entities/StudyResource" },
          "description": "Downloadable booklet library."
        }
      },
      {
        "path": "/users/{userId}/purchases/{purchaseId}",
        "definition": {
          "entityName": "Purchase",
          "schema": { "$ref": "#/backend/entities/Purchase" },
          "description": "Learner transaction history."
        }
      },
      {
        "path": "/purchases/{purchaseId}",
        "definition": {
          "entityName": "Purchase",
          "schema": { "$ref": "#/backend/entities/Purchase" },
          "description": "Root level purchase records for easy admin access."
        }
      },
      {
        "path": "/users/{userId}/testAttempts/{attemptId}",
        "definition": {
          "entityName": "TestAttempt",
          "schema": { "$ref": "#/backend/entities/TestAttempt" },
          "description": "Mock test results."
        }
      },
      {
        "path": "/users/{userId}/lessonProgress/{progressId}",
        "definition": {
          "entityName": "LessonProgress",
          "schema": { "$ref": "#/backend/entities/LessonProgress" },
          "description": "Real-time module tracking."
        }
      }
    ]
  }
}
